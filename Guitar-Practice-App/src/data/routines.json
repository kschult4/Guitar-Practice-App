{
  "monday": {
    "focus": "Speed Building",
    "description": "Build clean coordination between your fretting and picking hands. Speed comes from accuracy and relaxation, not force.",
    "exercises": [
      {
        "id": "ascending-chromatic-motif",
        "name": "Ascending Chromatic Motif",
        "description": "Play continuous 16th notes across strings.\n\n```\ne|----------------5-6-7-8-|\nB|------------5-6-7-8-----|\nG|--------5-6-7-8---------|\nD|----5-6-7-8-------------|\nA|-5-6-7-8----------------|\nE|------------------------|\n```",
        "tips": "Stay relaxed. No forearm tension.",
        "duration": 45,
        "reps": 3,
        "startBPM": 70,
        "bpmIncrement": 10
      },
      {
        "id": "asymmetrical-chromatic-grouping",
        "name": "Asymmetrical Chromatic Grouping",
        "description": "Group notes in 3s over 4/4.\n\n```\ne|----------------5-6-7-|\nB|------------5-6-------|\nG|--------5-6-----------|\nD|----5-6---------------|\nA|-5-6------------------|\nE|----------------------|\n```",
        "tips": "Accents shift — picking does not.",
        "duration": 45,
        "reps": 3,
        "startBPM": 70,
        "bpmIncrement": 10
      },
      {
        "id": "burst-then-relax-run",
        "name": "Burst Then Relax Run",
        "description": "Alternate slow notes with fast bursts.\n\n```\ne|----------------5-6-7-8-|\nB|------------------------|\n   s s s s f f f f\n```",
        "tips": "Release tension immediately after bursts.",
        "duration": 45,
        "reps": 3,
        "startBPM": 65,
        "bpmIncrement": 5
      },
      {
        "id": "single-string-speed-cycling",
        "name": "Single-String Speed Cycling",
        "description": "1-2-3-4 pattern on a single string.\n\n```\ne|-5-6-7-8-5-6-7-8-|\n```",
        "tips": "Expose inefficiencies.",
        "duration": 45,
        "reps": 3,
        "startBPM": 80,
        "bpmIncrement": 10
      }
    ]
  },

  "tuesday": {
    "focus": "String Skipping",
    "description": "Improve accuracy and control when moving across non-adjacent strings.",
    "exercises": [
      {
        "id": "skipped-triad-shapes",
        "name": "Skipped Triad Shapes",
        "description": "Triad shapes with string skips.\n\n```\ne|---------7---------|\nB|-----8-------8-----|\nG|-9---------------9-|\n```",
        "tips": "Silence between strings matters.",
        "duration": 45,
        "reps": 3,
        "startBPM": 60,
        "bpmIncrement": 5
      },
      {
        "id": "inside-outside-skip-alternation",
        "name": "Inside–Outside Skip Alternation",
        "description": "Same shape, different pick paths.\n\n```\ne|---------7-----------|\nB|-----8-------8-------|\nG|-9---------------9---|\n```",
        "tips": "No raking.",
        "duration": 45,
        "reps": 3,
        "startBPM": 60,
        "bpmIncrement": 5
      },
      {
        "id": "muted-skip-accuracy",
        "name": "Muted Skip Accuracy Drill",
        "description": "Muted fretting hand, focus on pick travel.\n\n```\ne|--x-----x-----x--|\nB|------x-----x----|\nG|x-----x----------|\n```",
        "tips": "Listen for clean contact.",
        "duration": 45,
        "reps": 3,
        "startBPM": 70,
        "bpmIncrement": 5
      },
      {
        "id": "single-note-skip-ladder",
        "name": "Single-Note Skip Ladder",
        "description": "One note per string.\n\n```\ne|--7-----------|\nB|------8-------|\nG|--9-----------|\nD|------9-------|\n```",
        "tips": "Deliberate pick movement.",
        "duration": 45,
        "reps": 3,
        "startBPM": 65,
        "bpmIncrement": 5
      }
    ]
  },

  "wednesday": {
    "focus": "Alternate Picking",
    "description": "Develop strict alternate picking with challenging crossings.",
    "exercises": [
      {
        "id": "scalar-alternate-line",
        "name": "Scalar Alternate Line",
        "description": "Strict down-up picking.\n\n```\ne|----------------5-7-8-|\nB|------------5-7------|\nG|------4-5-7----------|\nD|-5-7-----------------|\n```",
        "tips": "No economy picking.",
        "duration": 45,
        "reps": 3,
        "startBPM": 70,
        "bpmIncrement": 10
      },
      {
        "id": "string-crossing-displacement-run",
        "name": "String-Crossing Displacement Run",
        "description": "Odd groupings force crossings.\n\n```\ne|-------------5-7-|\nB|---------5-7-----|\nG|-----4-5---------|\nD|-5-7-------------|\n```",
        "tips": "Let mistakes show weaknesses.",
        "duration": 45,
        "reps": 3,
        "startBPM": 65,
        "bpmIncrement": 5
      },
      {
        "id": "two-string-crossing-loop",
        "name": "Two-String Crossing Loop",
        "description": "Short loop across two strings.\n\n```\ne|--5-7-5-7-|\nB|--5-7-5-7-|\n```",
        "tips": "Control pick escape.",
        "duration": 45,
        "reps": 3,
        "startBPM": 75,
        "bpmIncrement": 5
      },
      {
        "id": "accent-displacement-alternate",
        "name": "Accent Displacement Alternate Line",
        "description": "Accent every 3rd note.\n\n```\ne|--5-6-7-8-5-6-7-8-|\n   ^     ^     ^\n```",
        "tips": "Accents don't affect picking.",
        "duration": 45,
        "reps": 3,
        "startBPM": 70,
        "bpmIncrement": 5
      }
    ]
  },

  "thursday": {
    "focus": "Finger Stretching",
    "description": "Improve reach and independence. Comfort always comes first.",
    "exercises": [
      {
        "id": "four-fret-expansion",
        "name": "Four-Fret Expansion",
        "description": "Wide-span chromatic stretch.\n\n```\ne|--5---8-|\nB|--5---8-|\nG|--5---8-|\nD|--5---8-|\n```",
        "tips": "No pain.",
        "duration": 35,
        "reps": 3,
        "startBPM": 50,
        "bpmIncrement": 0
      },
      {
        "id": "held-anchor-stretch-line",
        "name": "Held-Anchor Stretch Line",
        "description": "Index finger stays planted.\n\n```\ne|--------|\nB|----6-9-|\nG|--5-----|\nD|-4------|\n```",
        "tips": "Anchor never lifts.",
        "duration": 35,
        "reps": 3,
        "startBPM": 50,
        "bpmIncrement": 0
      },
      {
        "id": "spider-stretch",
        "name": "Spider Stretch (1-3-2-4)",
        "description": "Non-linear finger order.\n\n```\ne|--5-7-6-8-|\n```",
        "tips": "Neutral wrist.",
        "duration": 35,
        "reps": 3,
        "startBPM": 45,
        "bpmIncrement": 0
      },
      {
        "id": "micro-shift-stretch",
        "name": "Micro-Shift Stretch",
        "description": "Shift up one fret each cycle.\n\n```\ne|--5---8--6---9--7---10-|\n```",
        "tips": "Stay relaxed.",
        "duration": 35,
        "reps": 3,
        "startBPM": 45,
        "bpmIncrement": 0
      }
    ]
  },

  "friday": {
    "focus": "Finger Strength",
    "description": "Build strength through legato articulation.",
    "exercises": [
      {
        "id": "legato-ladder",
        "name": "Hammer-On / Pull-Off Ladder",
        "description": "Minimal picking.\n\n```\ne|--5h7p5--|\nB|--5h7----|\n```",
        "tips": "Clear articulation.",
        "duration": 45,
        "reps": 3,
        "startBPM": 60,
        "bpmIncrement": 5
      },
      {
        "id": "offset-legato-accents",
        "name": "Offset Legato Accents",
        "description": "Accents shift.\n\n```\ne|--5h7h8p7p5--|\n```",
        "tips": "No extra pick attack.",
        "duration": 45,
        "reps": 3,
        "startBPM": 60,
        "bpmIncrement": 5
      },
      {
        "id": "descending-pull-off-drill",
        "name": "Descending Pull-Off Drill",
        "description": "Descending pull-offs only.\n\n```\ne|--8p7p5--|\n```",
        "tips": "Expose weak fingers.",
        "duration": 45,
        "reps": 3,
        "startBPM": 55,
        "bpmIncrement": 5
      },
      {
        "id": "held-note-legato",
        "name": "Held-Note Legato Independence",
        "description": "One finger holds while others move.\n\n```\ne|--5h7h8--|\nB|--5------|\n```",
        "tips": "No sympathetic movement.",
        "duration": 45,
        "reps": 3,
        "startBPM": 55,
        "bpmIncrement": 5
      }
    ]
  },

  "saturday": {
    "focus": "Fret Accuracy",
    "description": "Train clean landings and confident shifts.",
    "exercises": [
      {
        "id": "position-jump-motifs",
        "name": "Position Jump Motifs",
        "description": "Clean position jumps.\n\n```\ne|--5-7---------10-12--|\n```",
        "tips": "No sliding.",
        "duration": 45,
        "reps": 3,
        "startBPM": 65,
        "bpmIncrement": 5
      },
      {
        "id": "blind-position-targeting",
        "name": "Blind Position Targeting",
        "description": "Look away after first position.\n\n```\ne|--5-----------12--|\n```",
        "tips": "Trust muscle memory.",
        "duration": 45,
        "reps": 3,
        "startBPM": 60,
        "bpmIncrement": 5
      },
      {
        "id": "octave-jump-targeting",
        "name": "Octave Jump Targeting",
        "description": "Same note, different strings.\n\n```\ne|--5-----------|\nD|------7-------|\n```",
        "tips": "Visualize target.",
        "duration": 45,
        "reps": 3,
        "startBPM": 60,
        "bpmIncrement": 5
      },
      {
        "id": "delayed-landing-drill",
        "name": "Delayed Landing Drill",
        "description": "Pause before landing.\n\n```\ne|--5----(pause)----12--|\n```",
        "tips": "Mental prep before movement.",
        "duration": 45,
        "reps": 3,
        "startBPM": 55,
        "bpmIncrement": 5
      }
    ]
  },

  "sunday": {
    "focus": "Chord Transitions",
    "description": "Smooth chord changes and continuous motion.",
    "exercises": [
      {
        "id": "triad-flow",
        "name": "Triad Flow",
        "description": "Move shapes smoothly.\n\n```\ne|--5---7---8--|\nB|--5---7---8--|\nG|--5---7---8--|\n```",
        "tips": "Minimal lift.",
        "duration": 45,
        "reps": 3,
        "startBPM": 60,
        "bpmIncrement": 5
      },
      {
        "id": "voice-led-triad-transitions",
        "name": "Voice-Led Triad Transitions",
        "description": "One note moves.\n\n```\ne|--5---5---6--|\nB|--5---6---6--|\nG|--5---5---5--|\n```",
        "tips": "Voice leading first.",
        "duration": 45,
        "reps": 3,
        "startBPM": 55,
        "bpmIncrement": 5
      },
      {
        "id": "single-finger-pivot-changes",
        "name": "Single-Finger Pivot Changes",
        "description": "One finger anchors.\n\n```\ne|--5---7---8--|\nB|--5---7---8--|\n```",
        "tips": "Economy of motion.",
        "duration": 45,
        "reps": 3,
        "startBPM": 55,
        "bpmIncrement": 5
      },
      {
        "id": "rhythmic-delay-transitions",
        "name": "Rhythmic Delay Transitions",
        "description": "Delayed changes.\n\n```\ne|--5----(wait)----7--|\n```",
        "tips": "Stay relaxed.",
        "duration": 45,
        "reps": 3,
        "startBPM": 50,
        "bpmIncrement": 5
      }
    ]
  }
}
